# Google OAuth2 credentials (from Google Cloud Console -> APIs & Services -> Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Generated once via `npm run get-refresh-token`
GOOGLE_REFRESH_TOKEN=

# Allowed origin for CORS (your deployed Vercel frontend URL)
CORS_ORIGIN=http://localhost:5173

# Name of the root folder created in the owner's Drive
DRIVE_ROOT_FOLDER_NAME=PhotoUploads

# Port for the Express server (Render sets this automatically)
PORT=3001
